# ============================================
# 图审云平台 - Docker 环境变量示例
# ============================================
# 复制此文件为 .env 并修改相应配置
# ============================================

# 后端端口
BACKEND_PORT=8000

# 前端端口（开发模式直接访问 Vue）
FRONTEND_PORT=5173

# MySQL 配置（可选，如不配置则使用 SQLite）
# MYSQL_HOST=mysql
# MYSQL_PORT=3306
# MYSQL_DATABASE=tushen
# MYSQL_USER=tushen
# MYSQL_PASSWORD=tushen123

# 上传文件大小限制（字节）
# UPLOAD_MAX_SIZE=104857600

# 时区
# TZ=Asia/Shanghai
