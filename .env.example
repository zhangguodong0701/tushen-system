# ============================================
# 图审云平台 - 环境变量配置示例
# 复制此文件为 .env 并填入真实值
# ============================================

# ========== 安全配置（必须修改） ==========
# JWT 密钥：至少 32 位随机字符串
# 生成方式：python -c "import secrets; print(secrets.token_urlsafe(32))"
TUSHEN_SECRET_KEY=请在这里填入随机密钥

# ========== 数据库配置 ==========
# MySQL（生产环境）
# DATABASE_URL=mysql+pymysql://tushen:tushen_pass_2026@mysql:3306/tushen?charset=utf8mb4

# SQLite（本地开发，默认）
DATABASE_URL=sqlite:///./tushen.db

# ========== CORS 配置 ==========
# 允许的域名，逗号分隔，不要包含通配符
CORS_ORIGINS=http://localhost:5173,http://localhost:8000,https://你的域名.com

# ========== 上传配置 ==========
# 单文件最大大小（MB）
MAX_FILE_SIZE=50

# ========== Token 配置 ==========
# Token 过期时间（分钟），默认 1440（24小时）
ACCESS_TOKEN_EXPIRE_MINUTES=1440
